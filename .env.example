# Fantdev Trading Bot Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# ============================================
# CRITICAL - Bot Configuration
# ============================================
# Your Telegram bot token from @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# Admin chat/group ID for notifications
ADMIN_CHAT_ID=-1234567890

# ============================================
# Security & Authentication
# ============================================
# JWT secret for web authentication (generate a strong random string)
JWT_SECRET=change_this_to_random_string_min_32_chars

# Session secret for web sessions
SESSION_SECRET=change_this_to_another_random_string

# Webhook validation secret
WEBHOOK_SECRET=your_webhook_secret_here

# ============================================
# Server Configuration
# ============================================
# Python Flask server
PORTAL_SERVER_PORT=5000
PORTAL_SERVER_HOST=0.0.0.0

# TypeScript/Bun admin server
ADMIN_SERVER_PORT=3003
ADMIN_SERVER_HOST=localhost

# WebSocket server
WS_PORT=3004
WS_HOST=localhost

# Development server
DEV_SERVER_PORT=3000

# ============================================
# Database Configuration
# ============================================
# File paths
DATABASE_PATH=data/customer_database.json
CHAT_TRACKER_DB=chat_tracker.db
GROUP_MONITOR_DB=group_monitor.db
NOTIFICATIONS_DB=notifications.db

# Backup settings
ENABLE_AUTO_BACKUP=true
BACKUP_INTERVAL_HOURS=24
MAX_BACKUPS=7

# ============================================
# Feature Flags
# ============================================
ENABLE_WEBSOCKET=true
ENABLE_AUTO_REPORTER=true
ENABLE_ERROR_TRACKING=true
ENABLE_WORKER_THREADS=true
ENABLE_DEBUG_MODE=false
ENABLE_CHAT_TRACKING=true
ENABLE_PORTAL_INTEGRATION=true

# ============================================
# Alert Thresholds
# ============================================
LOW_BALANCE_THRESHOLD=100
LARGE_DEPOSIT_THRESHOLD=1000
LARGE_WITHDRAWAL_THRESHOLD=500
INACTIVE_DAYS_THRESHOLD=3

# ============================================
# API Configuration
# ============================================
# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MINUTES=1

# CORS settings
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3003
CORS_ALLOW_CREDENTIALS=true

# ============================================
# Cloudflare Worker (Optional)
# ============================================
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_KV_NAMESPACE_ID=
CLOUDFLARE_WORKER_ENV=development

# ============================================
# External Services (Optional)
# ============================================
# Email service
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@fantdev.com

# Push notifications
PUSH_SERVICE_KEY=
PUSH_SERVICE_URL=

# SMS service
SMS_API_KEY=
SMS_API_URL=

# ============================================
# Logging & Monitoring
# ============================================
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/app.log
ERROR_LOG_PATH=logs/error.log
DEBUG_LOG_PATH=logs/debug.log

# Performance monitoring
ENABLE_PERFORMANCE_MONITORING=false
PERFORMANCE_LOG_PATH=logs/performance.log

# ============================================
# Environment
# ============================================
NODE_ENV=development
PYTHON_ENV=development
TZ=UTC

# ============================================
# Development Tools
# ============================================
# Hot reload
ENABLE_HOT_RELOAD=true

# Source maps
GENERATE_SOURCEMAPS=true

# Testing
TEST_DATABASE_PATH=data/test_database.json
TEST_BOT_TOKEN=test_token_for_testing_only
TEST_ADMIN_CHAT_ID=-9876543210