# Fantdev Trading Bot Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# TELEGRAM BOT CONFIGURATION
# ============================================
BOT_TOKEN=your_bot_token_here
ADMIN_CHAT_ID=your_admin_chat_id_here
WEBHOOK_SECRET=generate_secure_webhook_secret

# ============================================
# DATABASE CONFIGURATION
# ============================================
DATABASE_PATH=customer_database.json
CHAT_TRACKER_DB=chat_tracker.db
GROUP_MONITOR_DB=group_monitor.db

# ============================================
# API CONFIGURATION
# ============================================
API_BASE_URL=http://localhost:3003/api
PORTAL_SERVER_PORT=5000
ADMIN_SERVER_PORT=3003
WORKER_URL=http://localhost:8787

# ============================================
# CLOUDFLARE CONFIGURATION
# ============================================
CLOUDFLARE_API_KEY=your_cloudflare_api_key_here
CLOUDFLARE_WORKER_URL=https://your-worker.workers.dev
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
CLOUDFLARE_ZONE_ID=your_zone_id_here

# ============================================
# AUTHENTICATION & SECURITY
# ============================================
JWT_SECRET=generate_secure_jwt_secret_min_32_chars
SESSION_SECRET=generate_secure_session_secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password

# ============================================
# REDIS CONFIGURATION (Optional)
# ============================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================
# WEBSOCKET CONFIGURATION
# ============================================
WS_PORT=3004
WS_PING_INTERVAL=30000
WS_MAX_CONNECTIONS=1000

# ============================================
# MONITORING & LOGGING
# ============================================
LOG_LEVEL=info
LOG_FILE=logs/app.log
ERROR_LOG_FILE=logs/error.log
DEBUG_MODE=false
ENABLE_METRICS=true

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# ============================================
# ENVIRONMENT SETTINGS
# ============================================
NODE_ENV=development
TZ=UTC

# ============================================
# REACT APP CONFIGURATION
# ============================================
REACT_APP_API_URL=http://localhost:3003/api
REACT_APP_WS_URL=ws://localhost:3004
REACT_APP_WORKER_URL=http://localhost:8787

# ============================================
# EXTERNAL SERVICES
# ============================================
TELEGRAM_API_URL=https://api.telegram.org
OPENAI_API_KEY=optional_openai_key
STRIPE_API_KEY=optional_stripe_key
STRIPE_WEBHOOK_SECRET=optional_stripe_webhook_secret

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_WEBSOCKET=true
ENABLE_AUTO_REPORTER=true
ENABLE_ERROR_TRACKING=true
ENABLE_RATE_LIMIT_MONITOR=true
ENABLE_WORKER_THREADS=true

# ============================================
# PERFORMANCE TUNING
# ============================================
MAX_POOL_SIZE=10
CONNECTION_TIMEOUT=5000
REQUEST_TIMEOUT=30000
WORKER_THREADS=4