# Environment Configuration for Fantdev Trading Bot
# Copy this file to .env and fill in your actual values

# =============================================================================
# TELEGRAM BOT CONFIGURATION
# =============================================================================
BOT_TOKEN=your_telegram_bot_token_here
ADMIN_CHAT_ID=your_admin_chat_id_here
WEBHOOK_SECRET=your_webhook_secret_here

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DATABASE_PATH=customer_database.json
CHAT_TRACKER_DB=chat_tracker.db
GROUP_MONITOR_DB=group_monitor.db

# =============================================================================
# SERVER PORTS (CONFIGURABLE)
# =============================================================================
# Main portal server port (default: 5000)
PORTAL_SERVER_PORT=5000

# Admin server port (default: 3003)
ADMIN_SERVER_PORT=3003

# WebSocket server port (default: 3004)
WS_PORT=3004

# Payment server port (default: 5001)
PAYMENT_SERVER_PORT=5001

# Dev server port (default: 3006)
DEV_SERVER_PORT=3006

# =============================================================================
# API BASE URLS (CONFIGURABLE)
# =============================================================================
# Base API URL for all API calls (default: http://localhost:3003/api)
API_BASE_URL=http://localhost:3003/api

# Portal server base URL (default: http://localhost:5000)
PORTAL_SERVER_URL=http://localhost:5000

# Admin server base URL (default: http://localhost:3003)
ADMIN_SERVER_URL=http://localhost:3003

# Payment API base URL (default: http://localhost:5001)
PAYMENT_API_URL=http://localhost:5001

# Telegram bot base URL (default: http://localhost:3004)
TELEGRAM_BOT_URL=http://localhost:3004

# WebSocket base URL (default: ws://localhost:3004)
WEBSOCKET_URL=ws://localhost:3004

# =============================================================================
# REACT APP CONFIGURATION
# =============================================================================
# React app API URL (default: http://localhost:3003/api)
REACT_APP_API_URL=http://localhost:3003/api

# React app WebSocket URL (default: ws://localhost:3004)
REACT_APP_WS_URL=ws://localhost:3004

# React app worker URL (default: http://localhost:8787)
REACT_APP_WORKER_URL=http://localhost:8787

# =============================================================================
# CLOUDFLARE CONFIGURATION
# =============================================================================
CLOUDFLARE_API_KEY=your_cloudflare_api_key_here
CLOUDFLARE_WORKER_URL=https://telegram-bot-worker.workers.dev
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here
CLOUDFLARE_ZONE_ID=your_cloudflare_zone_id_here

# Worker URL for Cloudflare workers (default: http://localhost:8787)
WORKER_URL=http://localhost:8787

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================
JWT_SECRET=your_jwt_secret_here_minimum_32_chars_in_production
SESSION_SECRET=your_session_secret_here
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# =============================================================================
# REDIS CONFIGURATION (OPTIONAL)
# =============================================================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your_redis_password_here
REDIS_DB=0

# =============================================================================
# EXTERNAL SERVICE URLS
# =============================================================================
# Telegram API URL (default: https://api.telegram.org)
TELEGRAM_API_URL=https://api.telegram.org

# OpenAI API Key (optional)
OPENAI_API_KEY=your_openai_api_key_here

# Stripe API Key (optional)
STRIPE_API_KEY=your_stripe_api_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# =============================================================================
# FEATURE FLAGS
# =============================================================================
ENABLE_WEBSOCKET=true
ENABLE_AUTO_REPORTER=true
ENABLE_ERROR_TRACKING=true
ENABLE_RATE_LIMIT_MONITOR=true
ENABLE_WORKER_THREADS=true

# =============================================================================
# LOGGING & MONITORING
# =============================================================================
LOG_LEVEL=info
LOG_FILE=logs/app.log
ERROR_LOG_FILE=logs/error.log
DEBUG_MODE=false
ENABLE_METRICS=true

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# =============================================================================
# ENVIRONMENT
# =============================================================================
NODE_ENV=development
TZ=UTC

# =============================================================================
# PERFORMANCE SETTINGS
# =============================================================================
MAX_POOL_SIZE=10
CONNECTION_TIMEOUT=5000
REQUEST_TIMEOUT=30000
WORKER_THREADS=4

# =============================================================================
# WEBHOOK & INTEGRATION SETTINGS
# =============================================================================
# WebSocket ping interval in milliseconds (default: 30000)
WS_PING_INTERVAL=30000

# Maximum WebSocket connections (default: 1000)
WS_MAX_CONNECTIONS=1000

# =============================================================================
# DEVELOPMENT & TESTING
# =============================================================================
# Test port for development (default: 3006)
TEST_PORT=3006

# Health check timeout in seconds (default: 5)
HEALTH_CHECK_TIMEOUT=5

# =============================================================================
# EXTERNAL INTEGRATION URLS
# =============================================================================
# Fantasy402.com integration (if applicable)
FANTASY402_BASE_URL=https://fantasy402.com

# Fire22 integration (if applicable)
FIRE22_BASE_URL=https://fire22.com

# Fantdev trading domain (if applicable)
FANTDEV_TRADING_URL=https://fantdev.trading
