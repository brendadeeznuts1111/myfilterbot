{
  "name": "bun-react-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"bun:dev:*\"",
    "dev:bot": "python3 src/bot/main.py",
    "dev:server": "bun --hot src/server/admin/index.ts",
    "dev:web": "bun run src/dev-server.ts",
    "start": "bun run start:prod",
    "start:prod": "NODE_ENV=production concurrently \"bun:start:bot\" \"bun:start:server\"",
    "start:bot": "python3 src/bot/main.py",
    "start:server": "NODE_ENV=production bun src/server/admin/index.ts",
    "build": "bun run src/build.ts",
    "test": "bun run test:all",
    "test:all": "concurrently \"bun:test:python\" \"bun:test:ts\"",
    "test:python": "python3 -m pytest tests/python/ -v",
    "test:ts": "NODE_ENV=test bun test tests/typescript/",
    "test:watch": "NODE_ENV=test bun test --watch tests/typescript/",
    "test:coverage": "NODE_ENV=test bun test --coverage tests/typescript/",
    "test:ci": "NODE_ENV=test bun test --reporter=junit --reporter-outfile=test-results/junit.xml tests/typescript/",
    "clean": "rm -rf dist coverage node_modules .pytest_cache",
    "clean:install": "bun run clean && bun install",
    "validate": "bun run src/validate_bun_native.ts",
    "worker:dev": "bunx wrangler dev cloudflare-worker/src/index.ts",
    "worker:deploy": "bunx wrangler deploy",
    "worker:build": "bun build cloudflare-worker/src/index.ts --target=browser --outdir=cloudflare-worker/dist",
    "lint": "eslint src/**/*.{ts,tsx}",
    "lint:fix": "eslint src/**/*.{ts,tsx} --fix",
    "format": "prettier --write src/**/*.{ts,tsx,json,css,md}",
    "format:check": "prettier --check src/**/*.{ts,tsx,json,css,md}",
    "quality": "bun run lint && bun run format:check"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.85.5",
    "bun-plugin-tailwind": "^0.0.15",
    "react": "^19",
    "react-dom": "^19",
    "recharts": "^3.1.2",
    "tailwindcss": "^4.1.11"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240129.0",
    "@tanstack/react-query-devtools": "^5.85.5",
    "@types/node": "^24.3.0",
    "@typescript-eslint/eslint-plugin": "^8.40.0",
    "@typescript-eslint/parser": "^8.40.0",
    "bun-types": "^1.2.20",
    "concurrently": "^8.2.2",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "prettier": "^3.6.2",
    "wrangler": "^3.28.2"
  },
  "module": "src/index.tsx",
  "peerDependencies": {
    "typescript": "^5"
  }
}
