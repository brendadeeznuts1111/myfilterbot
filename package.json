{
  "name": "fantdev-trading-bot",
  "version": "2.1.0",
  "private": true,
  "type": "module",
  "description": "Enterprise-grade Telegram trading platform with web portals, real-time monitoring, and automated reporting",
  "keywords": [
    "telegram",
    "bot",
    "trading",
    "typescript",
    "bun",
    "react"
  ],
  "author": "Fantdev Trading Systems",
  "scripts": {
    "dev": "concurrently \"bun run dev:*\"",
    "dev:bot": "python3 src/bot/main.py",
    "dev:server": "bun --env-file=.env.local --define process.env.NODE_ENV=\"'development'\" --define ENABLE_CONSOLE_LOGS=true --define ENABLE_DEBUG_MODE=true --hot src/server/admin/index.ts",
    "dev:web": "bun --env-file=.env.local --define process.env.NODE_ENV=\"'development'\" --define ENABLE_DEV_TOOLS=true src/dev-server.ts",
    "dev:admin": "bun --env-file=.env.local --define process.env.NODE_ENV=\"'development'\" --hot src/client/admin-mobile/dev-server.ts",
    "start": "bun run start:prod",
    "start:prod": "NODE_ENV=production concurrently \"bun run start:bot\" \"bun run start:server\"",
    "start:bot": "python3 src/bot/main.py",
    "start:server": "bun --define process.env.NODE_ENV=\"'production'\" --define ENABLE_CONSOLE_LOGS=false --define ENABLE_DEBUG_MODE=false src/server/admin/index.ts",
    "start:admin": "bun --define process.env.NODE_ENV=\"'production'\" src/client/admin-mobile/dev-server.ts",
    "build": "bun run scripts/build-with-defines.js",
    "build:legacy": "bun run src/build.ts",
    "test": "bun run test:all",
    "test:all": "concurrently \"bun run test:python\" \"bun run test:ts\"",
    "test:python": "python3 -m pytest tests/python/ -v",
    "test:ts": "bun --env-file=.env.local --define process.env.NODE_ENV=\"'test'\" --define ENABLE_CONSOLE_LOGS=true test tests/typescript/",
    "test:watch": "bun --env-file=.env.local --define process.env.NODE_ENV=\"'test'\" test --watch tests/typescript/",
    "test:coverage": "bun --env-file=.env.local --define process.env.NODE_ENV=\"'test'\" test --coverage tests/typescript/",
    "test:ci": "bun --env-file=.env.local --define process.env.NODE_ENV=\"'test'\" test --reporter=junit --reporter-outfile=test-results/junit.xml tests/typescript/",
    "clean": "rm -rf dist coverage node_modules .pytest_cache",
    "clean:install": "bun run clean && bun install",
    "validate": "bun run src/validate_bun_native.ts",
    "validate:repo": "bun run src/validate_repo_wide_bun_native.ts",
    "type-check": "tsc --noEmit",
    "worker:dev": "bunx --package wrangler wrangler dev cloudflare-worker/src/index.ts",
    "worker:deploy": "bunx --package wrangler wrangler deploy",
    "worker:build": "bun build cloudflare-worker/src/index.ts --target=browser --outdir=cloudflare-worker/dist",
    "lint": "eslint src/**/*.{ts,tsx}",
    "lint:fix": "eslint src/**/*.{ts,tsx} --fix",
    "lint:python": "ruff check src/bot tests/python",
    "lint:python:fix": "ruff check --fix src/bot tests/python",
    "format": "prettier --write src/**/*.{ts,tsx,json,css,md}",
    "format:check": "prettier --check src/**/*.{ts,tsx,json,css,md}",
    "format:python": "black src/bot tests/python && isort src/bot tests/python",
    "format:python:check": "black --check src/bot tests/python && isort --check-only src/bot tests/python",
    "quality": "bun run lint && bun run format:check",
    "quality:python": "bun run lint:python && bun run format:python:check",
    "quality:all": "bun run quality && bun run quality:python",
    "metrics:baseline": "bun run scripts/collect_metrics.ts --collect-baseline",
    "metrics:compare": "bun run scripts/collect_metrics.ts --compare",
    "metrics:monitor": "bun run scripts/collect_metrics.ts --monitor",
    "gen:index": "bun run scripts/gen-index.ts",
    "error:budget": "bun run scripts/error_budget.ts",
    "ci": "bun run lint && bun run type-check && bun run test && python -m pytest tests/python -q",
    "docs:monitor": "bun run scripts/monitor-documentation-pipelines.ts",
    "docs:check-health": "bun run scripts/monitor-documentation-pipelines.ts",
    "docs:analyze-feedback": "bun run scripts/analyze-feedback.ts",
    "docs:feedback-report": "bun run scripts/analyze-feedback.ts",
    "ts:analyze-errors": "bun run scripts/analyze-typescript-errors.ts",
    "ts:error-report": "bun run scripts/analyze-typescript-errors.ts",
    "prepare": "husky install"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": ["eslint --fix", "prettier --write"],
    "*.py": ["black --quiet", "isort --profile black"]
  },
  "dependencies": {
    "@tanstack/react-query": "^5.85.5",
    "bun-plugin-tailwind": "^0.0.15",
    "grammy": "^1.38.1",
    "hono": "^4.9.4",
    "jose": "^6.0.13",
    "lucide-react": "^0.541.0",
    "pydantic-settings": "^0.0.1-security",
    "react": "^19",
    "react-dom": "^19",
    "react-router-dom": "^7.8.2",
    "recharts": "^3.1.2",
    "tailwindcss": "^4.1.11",
    "telegram": "^2.26.22",
    "zod": "^4.1.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240129.0",
    "@tanstack/react-query-devtools": "^5.85.5",
    "@types/node": "^24.3.0",
    "@typescript-eslint/eslint-plugin": "^8.40.0",
    "@typescript-eslint/parser": "^8.40.0",
    "bun-types": "^1.1.20",
    "concurrently": "^8.2.2",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "husky": "^8.0.0",
    "lint-staged": "^16.1.5",
    "prettier": "^3.6.2",
    "wrangler": "^3.28.2"
  },
  "module": "src/index.tsx",
  "peerDependencies": {
    "typescript": "^5"
  },
  "engines": {
    "bun": ">=1.2.20",
    "node": ">=20"
  },
  "sideEffects": [
    "**/*.css",
    "src/styles/**/*",
    "src/static/**/*",
    "src/html/**/*",
    "src/client/**/*.css"
  ]
}
